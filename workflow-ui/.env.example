# Defaults use Vercel/dev proxy paths (see vite.config.ts & vercel.json).
# Override with full URLs only if you call APIs directly (requires CORS on backends).

VITE_OPERATION_API_BASE=/api/proxy/operation
VITE_ONLINE_API_BASE=/api/proxy/online

# Direct Render URLs (optional):
# VITE_OPERATION_API_BASE=https://workflow-operation-api.onrender.com/api
# VITE_ONLINE_API_BASE=https://workflow-online-api.onrender.com/api

# Set to 0 to use real APIs in dev (proxy). Omit or 1 to use mock server when available.
# VITE_USE_MOCK=0
