# AI 网关配置示例。复制为 .env 后填写。真实 .env 不入库（见上层 .gitignore）。

# 后端：本机 Ollama 的 OpenAI 兼容接口（保持 localhost，别改成 0.0.0.0）
OLLAMA_BASE_URL=http://127.0.0.1:11434

# 鉴权模式：apikey（先跑通）| clerk（最终）| both（过渡）| none（仅本地调试）
AUTH_MODE=apikey

# --- apikey 模式：随机生成一串长密钥，workflow UI 调用时放进 Authorization: Bearer ---
GATEWAY_API_KEY=换成一串很长的随机字符串

# --- clerk 模式：从 Clerk 后台拿（Frontend API / Issuer）---
# 形如 https://your-app.clerk.accounts.dev 或生产 https://clerk.你的域名
CLERK_ISSUER=
# 一般留空即可（默认 = {CLERK_ISSUER}/.well-known/jwks.json）
CLERK_JWKS_URL=
# 授权方校验：填 workflow UI 的源，多个逗号分隔（如 https://workflow-ui-gamma.vercel.app）
CLERK_AUTHORIZED_PARTIES=

# CORS：允许哪些网页源调用本网关（workflow UI 的地址）。多个逗号分隔。
ALLOWED_ORIGINS=https://workflow-ui-gamma.vercel.app
